PORT=3001
DATABASE_PATH=./data/excelboard.db
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# Microsoft (OneDrive / Azure AD)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/sources/onedrive/callback

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_SAS_TOKEN=

# Looker
LOOKER_BASE_URL=
LOOKER_CLIENT_ID=
LOOKER_CLIENT_SECRET=

# Security
ENCRYPTION_KEY=change-this-to-a-32-char-random-string
SESSION_SECRET=change-this-to-another-random-string
